generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id               Int      @id @default(autoincrement())
  title            String
  thumbnailConcept String   @db.Text
  script           String?  @db.Text
  status           String   @default("idea")
  category         String
  tags             String[]
  estimatedLength  String?
  hookLine         String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  audios           Audio[]
}

model Pitch {
  id               Int            @id @default(autoincrement())
  title            String
  format           String
  pitchType        String         @default("trending")
  angle            String         @db.Text
  hookLine         String         @db.Text
  talkingPoints    String[]
  performanceScore Int            @default(0)
  status           String         @default("pending")
  generatedScript  String?        @db.Text
  aiProvider       String?
  aiModel          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  calendarSlots    CalendarSlot[]
}

model CalendarSlot {
  id         Int      @id @default(autoincrement())
  weekNumber Int
  year       Int
  dayOfWeek  String
  slotType   String
  date       DateTime
  pitchId    Int?
  pitch      Pitch?   @relation(fields: [pitchId], references: [id])
  videoId    Int?
  status     String   @default("open")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Audio {
  id          Int      @id @default(autoincrement())
  videoId     Int
  video       Video    @relation(fields: [videoId], references: [id])
  voiceId     String
  voiceName   String
  isTest      Boolean  @default(false)
  audioUrl    String?  @db.Text
  createdAt   DateTime @default(now())
}

model ChannelStat {
  id          Int      @id @default(autoincrement())
  youtubeId   String   @unique
  title       String
  views       Int
  duration    Int
  format      String
  tags        String[]
  publishedAt DateTime
  lastChecked DateTime @default(now())
}
